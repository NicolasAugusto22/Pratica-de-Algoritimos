<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
<h1>Quanto você pesa ?</h1>
    <input type="text" id="input_peso">
<h1>Qual é sua altura em (metros) ?</h1>
    <input type="text" id="input_altura">
    <button onclick="imc()">Calcular IMC</button>
    <div id="div_mensagem"></div>
</body>
</html>
<script>
    function imc(){
div_mensagem.innerHTML = 'Seu IMC é:' + input_peso.value / input_altura.value ** 2 ;
 }
</script>
